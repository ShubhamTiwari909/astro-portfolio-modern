---
import { footerContent, siteMeta } from "@data/portfolio-site";
---

<footer
  class="bg-v2-background w-full py-12 px-8 border-t border-v2-on-surface/5"
>
  <div
    class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto text-center md:text-left"
  >
    <div>
      <span
        class="text-xl font-bold text-v2-on-surface font-v2-headline mb-4 block"
        >{siteMeta.brandName}</span
      >
      <p
        class="font-v2-body text-sm tracking-wide text-v2-on-surface/40"
      >
        {footerContent.tagline}
      </p>
    </div>
    <div class="flex gap-8 mt-8 md:mt-0">
      {
        footerContent.links.map((link) => (
          <a
            class="text-v2-on-surface/40 hover:text-v2-secondary-fixed transition-colors duration-300 font-v2-body text-sm tracking-wide"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
