---
import { siteMeta, topNavLinks } from "@data/portfolio-site";
---

<nav
  class="bg-v2-background/80 backdrop-blur-xl text-v2-primary font-v2-headline tracking-tight font-bold text-sm uppercase sticky top-0 z-50 w-full"
  id="top-nav"
>
  <div
    class="flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto"
  >
    <div
      class="text-2xl font-black tracking-tighter text-v2-on-surface font-v2-headline"
    >
      {siteMeta.brandName}
    </div>
    <div class="hidden md:flex gap-8 items-center">
      {
        topNavLinks.map((link, i) => (
          <a
            href={link.href}
            class="transition-all duration-300 ease-in-out"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-4">
      <a
        class="bg-v2-primary text-v2-on-primary px-3 py-2 rounded-full font-bold scale-95 active:scale-90 transition-transform"
        href="#contact">Contact</a
      >
      <a
        class="bg-v2-primary text-v2-on-primary px-3 py-2 rounded-full font-bold scale-95 active:scale-90 transition-transform"
        href="#about">About</a
      >
    </div>
  </div>
</nav>

